# Misir backend configuration. Copy to .env and fill in.
# Required values have no default and the app will not start without them.
# Everything else is optional (defaults shown).

# ── Required ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                       # e.g. https://<project>.supabase.co
SUPABASE_SERVICE_KEY=               # service-role key (NEVER expose to clients)
CLERK_JWKS_URL=                     # https://<clerk-frontend-api>/.well-known/jwks.json

# ── Clerk / auth ─────────────────────────────────────────────────────────────
CLERK_JWT_TEMPLATE=misir-backend
# Issuer is verified by default (auto-derived from CLERK_JWKS_URL). Set explicitly
# only for a non-standard JWKS URL.
CLERK_ISSUER=
# Audience verification is OPT-IN. Leave blank unless you mint tokens with a JWT
# template that stamps `aud` (default getToken() tokens do not).
CLERK_JWT_AUDIENCE=
# Enables deleting the Clerk identity on account erasure (GDPR Art 17 fan-out).
# When blank, Clerk deletion is skipped and flagged in the audit log.
CLERK_SECRET_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed browser origins (frontend). Example:
# CORS_ORIGINS=["https://app.misir.example","https://misir.example"]
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

LOG_LEVEL=INFO

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIM=768
# 'local' loads the torch model in-process (~1-1.5GB RAM). 'nomic' calls the
# hosted API (same model + 768 dims, no DB migration) — fits small-RAM hosts.
EMBEDDING_PROVIDER=local
NOMIC_API_KEY=                      # required when EMBEDDING_PROVIDER=nomic
NOMIC_EMBED_URL=https://api-atlas.nomic.ai/v1/embedding/text

CROSS_SPACE_SIMILARITY_THRESHOLD=0.72

# ── Groq (LLM) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
LLM_MODEL=qwen/qwen3-32b
LLM_MAX_TOKENS=1024
# Qwen3 is a reasoning model: it emits a <think> chain before its answer.
# "hidden" strips that server-side so the structured-JSON parsers only ever see
# the answer. Only relevant while LLM_MODEL is a reasoning model.
GROQ_REASONING_FORMAT=hidden
GROQ_TPM_LIMIT=30000               # account-wide tokens/min (free tier)
GROQ_RPM_LIMIT=30                  # account-wide requests/min (free tier)
GROQ_MAX_WAIT_SECONDS=30.0
GROQ_DEFAULT_TOKEN_ESTIMATE=500

# ── Chat ──────────────────────────────────────────────────────────────────────
CHAT_LLM_MODEL=                    # blank → falls back to LLM_MODEL
CHAT_MAX_CONTEXT_TOKENS=10000
CHAT_MAX_HISTORY_MESSAGES=50
CHAT_MAX_RESPONSE_TOKENS=2048

# ── Synthesis / scoring ──────────────────────────────────────────────────────
STAGE_A_K_TODAY=15
STAGE_A_K_WEEK=25
STAGE_A_K_MONTH=40
SYNTHESIS_MIN_ENGAGEMENT=passive   # passive | active | deep (ai-chat bypasses)
SYNTHESIS_WEB_MIN_WORDS=200
RECENCY_LAMBDA=0.05
RESEARCH_DEPTH_TARGET=10
NUDGE_REFRESH_COOLDOWN_MINUTES=30  # throttle the Groq-firing nudge refresh

# ── Rate limiting / DoS ───────────────────────────────────────────────────────
# PRODUCTION CHECKLIST — both are required or the limits are decorative:
#   1. RATE_LIMIT_STORAGE=redis (+ REDIS_URL). 'memory' is per-process: limits
#      reset per worker/dyno and are NOT shared across instances.
#   2. Run uvicorn with --forwarded-allow-ips (see Procfile) when behind a
#      proxy/router, or the IP-keyed global limit sees one shared proxy IP and
#      a single noisy client can 429 every user.
RATE_LIMIT_STORAGE=memory
REDIS_URL=redis://localhost:6379
RATE_LIMIT_DEFAULT=240/minute      # global safety net per user/IP
RATE_LIMIT_LLM=20/minute           # chat streaming
RATE_LIMIT_GENERATE=10/minute      # AI space generation
RATE_LIMIT_REGENERATE=10/minute    # forced report regeneration
RATE_LIMIT_DASHBOARD=60/minute     # dashboard
RATE_LIMIT_CAPTURE=120/minute      # artifact capture
MAX_REQUEST_BODY_BYTES=2000000     # ~2 MB body-size guard

# ── Job queue ─────────────────────────────────────────────────────────────────
# When true (+ REDIS_URL), post-capture embedding/synthesis run in a separate
# worker (python -m infrastructure.jobs.worker) so they survive ephemeral hosts.
# REQUIRES running the worker, or jobs pile up. Default false → in-process tasks.
JOB_QUEUE_ENABLED=false

# ── Privacy / data-rights ─────────────────────────────────────────────────────
PRIVACY_POLICY_VERSION=2026-06-07  # bump on policy changes to trigger re-consent
REQUIRE_CAPTURE_CONSENT=true       # server-side capture consent gate
RETENTION_DAYS=400                 # MUST match the published privacy policy
DATA_REGION=US                     # US | EU | ... (records residency intent)
INTERNAL_OPS_TOKEN=                # protects POST /internal/purge-expired (blank = disabled)

# ── Product analytics (PostHog, server-side) ──────────────────────────────────
POSTHOG_API_KEY=                   # blank = server-side analytics disabled (no-op)
POSTHOG_HOST=https://us.i.posthog.com  # project home region (us.i… or eu.i…)
