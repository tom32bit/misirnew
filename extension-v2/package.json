{
  "name": "misir-extension-v2",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy:ort": "node scripts/copy-ort.mjs",
    "dev": "npm run copy:ort && vite",
    "prebuild": "npm run copy:ort",
    "build": "tsc && vite build && node scripts/trim-ort.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "vitest run --config vitest.eval.config.ts",
    "lint": "eslint . --ext ts,tsx",
    "postinstall": "npm run copy:ort"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@mozilla/readability": "^0.5.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "consola": "^3.2.3",
    "dexie": "^4.0.11",
    "ky": "^1.7.2",
    "lucide-react": "^0.447.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2",
    "wink-eng-lite-web-model": "^1.8.0",
    "wink-nlp": "^2.3.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@types/chrome": "^0.0.278",
    "@types/mozilla__readability": "^0.4.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.9"
  }
}
